# ═══════════════════════════════════════════════════════════════
#   CNGSM — S.O.H.-X Environment Configuration (EXAMPLE)
#   Compatível com: Anthropic API (Claude) e DeepSeek via /anthropic
# ═══════════════════════════════════════════════════════════════

# ── API Key ──────────────────────────────────────────────────────
# Para DeepSeek:  ANTHROPIC_API_KEY=sua_chave_deepseek
# Para Anthropic: ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY="YOUR_KEY_HERE"

# ── Base URL ─────────────────────────────────────────────────────
# DeepSeek (compatível Anthropic):
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Anthropic nativo (descomente para usar Claude):
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Modelos ──────────────────────────────────────────────────────
# DeepSeek:
ANTHROPIC_MODEL=deepseek-chat
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-chat

# Anthropic (descomente para Claude):
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-20250514

# ── Timeouts ─────────────────────────────────────────────────────
API_TIMEOUT_MS=600000

# ── Claude Code (opcional) ────────────────────────────────────────
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# ── CNGSM Paths ──────────────────────────────────────────────────
# Local onde as tarefas e logs do Hormuz serão persistidos
HORMUZ_HOME=./.hormuz

# ── Servidor backend ─────────────────────────────────────────────
# Mude para 127.0.0.1 para acesso estritamente local
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
